# ── Alwaysdata Production ──────────────────────────────────
# Copiez ces variables dans l'interface d'administration
# Alwaysdata : Web > Sites > [votre-site] > Environnement
# ───────────────────────────────────────────────────────────

NODE_ENV=production

# Port d'écoute — Alwaysdata fournit IP et PORT via les
# variables d'environnement IP et PORT dans la config du site
# (ne pas définir PORT manuellement, Alwaysdata s'en charge)
# PORT=3000

# ── MySQL Alwaysdata ───────────────────────────────────────
# Créez une base MySQL dans l'admin Alwaysdata (Bases de données > MySQL)
# Les identifiants sont fournis dans la même section
DB_HOST=mysql-[votre_compte].alwaysdata.net
DB_PORT=3306
DB_USER=[votre_compte]
DB_PASSWORD=[votre_mot_de_passe]
DB_NAME=[votre_compte]_sportbook

# ── JWT ────────────────────────────────────────────────────
JWT_SECRET=une_cle_secrete_tres_longue_et_aleatoire
JWT_EXPIRES_IN=7d

# ── API ────────────────────────────────────────────────────
# En production, le frontend utilise une URL relative (/api)
# car Express sert les fichiers statiques du frontend
API_URL=https://[votre-site].alwaysdata.net
CORS_ORIGINS=https://[votre-site].alwaysdata.net

# ── SMTP (optionnel) ──────────────────────────────────────
# SMTP_HOST=...
# SMTP_PORT=...
# SMTP_SECURE=true
# SMTP_USER=...
# SMTP_PASS=...
# SMTP_FROM=noreply@votredomaine.fr
